# Copy to .env and fill in your keys once — then: npm run playground

# ── Ollama (free local testing — no API key) ─────────────────────────────────
# Requires: ollama serve && ollama pull llama3.1:8b
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_COMPOSITION_MODEL=llama3.1:8b
# OLLAMA_SECTION_MODEL=llama3.1:8b          # or qwen2.5-coder:7b for faster (weaker copy)
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# SKIP_VISION=1                             # local models have no vision — required for Ollama

# ── OpenRouter (paid — one key, many models) ─────────────────────────────────
# Get key: https://openrouter.ai/keys
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# Budget stack (~$0.05–0.20/site, ~25–80 sites on $5 — see src/llm/openrouter-models.ts)
# OPENROUTER_MODEL_TIER=budget          # default
# OPENROUTER_MODEL_TIER=quality         # slightly better, ~2× cost
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_COMPOSITION_MODEL=google/gemini-2.5-flash
# OPENROUTER_SECTION_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
# OPENROUTER_HTTP_REFERER=http://localhost:3847
# OPENROUTER_APP_NAME=website-generator

# Groq — https://console.groq.com/keys (comment out if using OpenRouter)
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_COMPOSITION_MODEL=llama-3.3-70b-versatile
# GROQ_SECTION_MODEL=llama-3.1-8b-instant
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_REQUEST_DELAY_MS=600

# Mistral — https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=
# LLM_PROVIDER=mistral
# MISTRAL_VISION_MODEL=mistral-medium-latest

# OpenAI (vision works out of the box with gpt-4o-mini)
# OPENAI_API_KEY=
# LLM_PROVIDER=openai

# Rate limits (applies to all providers)
# LLM_MAX_CONCURRENCY=3                   # default 3; use 4–6 with PIPELINE_FAST=1
# LLM_REQUEST_DELAY_MS=250                # auto 50ms when concurrency ≥ 4
# LLM_MAX_RETRIES=4                         # default 4 (was 8); billing errors never retry
# LLM_MAX_TOKENS=3072                       # global cap override

# Fast pipeline (~3–4 min/site on Groq/OpenRouter — similar quality, fewer round-trips)
# PIPELINE_FAST=1                           # parallel sections, unified copy+media, skip director retries
# SECTION_FILL_CONCURRENCY=6                # sections filled in parallel (default 6 in fast mode)
# PIPELINE_UNIFIED_SECTION=1                # one LLM call per section for copy+media (on by default with FAST)
# PIPELINE_CREATIVE_LLM=1                   # force creative director LLM even in fast mode
# PIPELINE_DIRECTOR_RETRIES=1               # retry chrome/motion/layout on QA fail even in fast mode
# PIPELINE_DOUBLE_REFINE=1                  # second design refine on QA fail even in fast mode

# Aggressive cost savings (opt-in — skips some LLM agents, lower quality)
# LLM_BUDGET_MODE=1
# LLM_BUDGET_DESIGN=1                       # keep design LLM when budget mode on
# LLM_BUDGET_DIRECTORS=1                    # keep motion/layout/chrome LLM when budget on
# LLM_BUDGET_CREATIVE=1                     # keep creative director LLM when budget on

# Pipeline
# OUTPUT_MODE=react          # default — Framer-parity Next.js codegen
# OUTPUT_MODE=html           # legacy block/card HTML pipeline
CUSTOM_HERO_CODEGEN=0        # set 1 for bespoke hero TSX (extra LLM cost)

# Vision QA + retry (screenshots via Playwright; needs vision-capable LLM)
# SKIP_VISION=1              # set to disable vision QA entirely (saves ~$0.01–0.03/site)
# SKIP_PLAYWRIGHT_SETUP=1    # skip auto browser install on startup

# Stock photos — Pexels recommended (free key: https://www.pexels.com/api/)
PEXELS_API_KEY=

# Fallbacks without keys: Openverse → Picsum
# PIXABAY_API_KEY=

# PLAYGROUND_PORT=3847
# REACT_BUILD_TIMEOUT_MS=300000
# PIPELINE_JSON_LOG=1

# Supabase hosting (Postgres + Storage) — server-side only
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SITES_BUCKET=sites
# AUTO_PUBLISH=1              # upload out/ to Storage after successful React build
#
# Public buckets serve HTML as plain text (Supabase security). Edge functions are also
# rewritten to text/plain on browser GET — static HTML cannot render on Supabase URLs.
# Use Cloudflare Pages for a live rendered site (free):
#   npx wrangler login
#   npm run hosting:pages -- 2n-fitness
# Live URL: https://main.wg-2n-fitness.pages.dev/preview/
#
# SUPABASE_SITE_FUNCTION=serve-site   # optional API/asset proxy only — not for HTML preview
# Then deploy: npm run supabase:deploy-site
# SITE_PUBLIC_BASE_URL=https://{slug}.yourplatform.com
