# Copy to .env and fill in your keys once — then: npm start

# Groq — https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
# OUTPUT_MODE=react   # default — Framer-parity Next.js codegen
# OUTPUT_MODE=html     # legacy block/card HTML pipeline

# Mistral — https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=
# LLM_PROVIDER=mistral
# LLM_MODEL=mistral-medium-latest

# Stock photos — Pexels recommended (free key: https://www.pexels.com/api/)
PEXELS_API_KEY=

# Fallbacks without keys: Openverse → Picsum
# Pixabay (optional, if you have a key later)
# PIXABAY_API_KEY=

# OPENAI_API_KEY=
# LLM_PROVIDER=openai
# PLAYGROUND_PORT=3847
# REACT_PREVIEW_PORT=3850   # localhost URL for built Next.js preview iframe
# SKIP_VISION=1
